# ==============================================================================
# Hospital Information Assistance — Docker Ignore Rules
# ==============================================================================
# WHY THIS FILE EXISTS:
#   This file prevents unnecessary or sensitive files from being copied into the
#   Docker build context during image creation.
#   It keeps the build fast, minimizes the final image size, and prevents
#   secrets (like local `.env` files) from leaking into the container image.
# ==============================================================================

# Version Control
.git
.gitignore

# Python caching and virtual environments
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
ENV/
pip-log.txt
pip-delete-this-directory.txt

# Environment secrets (highly sensitive — should not be baked into the image)
.env
.env.local
.env.*.local

# IDE configurations
.idea/
.vscode/
*.swp
*.swo

# Docker files themselves (not needed inside the image)
Dockerfile
docker-compose.yml
.dockerignore

# OS specific files
.DS_Store
Thumbs.db

# Documentation & Logs
*.log
docs/
README.md
