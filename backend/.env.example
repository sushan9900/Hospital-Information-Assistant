# ==============================================================================
# Hospital Information Assistance — Backend Environment Variables
# ==============================================================================
# HOW TO USE:
#   1. Copy this file and rename it to ".env"
#   2. Fill in your actual values (do NOT share .env with anyone)
#   3. Never commit the .env file to GitHub (it is already in .gitignore)
# ==============================================================================

# ------------------------------------------------------------------------------
# APPLICATION SETTINGS
# General settings for the FastAPI application.
# ------------------------------------------------------------------------------

# The name of your application (shown in Swagger UI)
APP_NAME="Hospital Information Assistance"

# App version (shown in Swagger UI)
APP_VERSION="1.0.0"

# Debug mode: set to True during development, False in production
DEBUG=True

# The environment the app is running in: "development", "production"
ENVIRONMENT=development

# Allowed origins for CORS (Cross-Origin Resource Sharing)
# In development, allow all. In production, replace with your frontend URL.
# Example: ALLOWED_ORIGINS=https://your-frontend.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ------------------------------------------------------------------------------
# DATABASE SETTINGS
# Neon PostgreSQL connection string.
# Get your connection string from: https://neon.tech
#
# Format: postgresql+asyncpg://user:password@host/dbname
# ------------------------------------------------------------------------------

# Async database URL (used by SQLAlchemy for async operations)
DATABASE_URL=postgresql+asyncpg://your_user:your_password@your_neon_host/your_database

# Sync database URL (used by Alembic for migrations — uses psycopg2)
SYNC_DATABASE_URL=postgresql+psycopg2://your_user:your_password@your_neon_host/your_database

# ------------------------------------------------------------------------------
# JWT AUTHENTICATION SETTINGS
# Used to create and verify secure login tokens.
#
# SECRET_KEY: A long, random, secret string. Generate one using:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# ALGORITHM: The algorithm used to sign tokens. HS256 is standard.
#
# ACCESS_TOKEN_EXPIRE_MINUTES: How long a login token stays valid.
# ------------------------------------------------------------------------------

# Secret key for signing JWT tokens — NEVER share this!
SECRET_KEY=your_super_secret_key_here_change_this_in_production

# JWT signing algorithm
ALGORITHM=HS256

# Token expiry in minutes (e.g. 60 = 1 hour, 1440 = 1 day)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ------------------------------------------------------------------------------
# GROQ API SETTINGS
# Used for AI chatbot and RAG response generation.
# Get your API key from: https://console.groq.com
# ------------------------------------------------------------------------------

# Your Groq API key
GROQ_API_KEY=your_groq_api_key_here

# The Groq model to use for chat responses
# Recommended: llama3-8b-8192 (fast) or llama3-70b-8192 (smarter)
GROQ_MODEL=llama3-8b-8192

# ------------------------------------------------------------------------------
# QDRANT VECTOR DATABASE SETTINGS
# Used for storing and searching embeddings (RAG feature).
# Get your Qdrant Cloud URL and API key from: https://cloud.qdrant.io
# ------------------------------------------------------------------------------

# Your Qdrant Cloud cluster URL
QDRANT_URL=https://your-cluster-id.us-east4-0.gcp.cloud.qdrant.io

# Your Qdrant API key
QDRANT_API_KEY=your_qdrant_api_key_here

# The name of the collection to store embeddings in
QDRANT_COLLECTION_NAME=hospital_info

# ------------------------------------------------------------------------------
# EMBEDDING MODEL SETTINGS
# FastEmbed uses a local model (no API key needed).
# Model: BAAI/bge-small-en-v1.5
# Dimensions: 384
# Similarity: Cosine
# ------------------------------------------------------------------------------

# The embedding model name (do not change unless switching models)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Number of dimensions the model produces
EMBEDDING_DIMENSIONS=384
